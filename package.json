{
  "name": "@ssen/eslint-plugin-solid",
  "version": "2.0.0-dev.3",
  "description": "Solid-specific linting rules for ESLint.",
  "type": "module",
  "keywords": [
    "eslint",
    "eslintplugin",
    "solid",
    "solidjs",
    "reactivity"
  ],
  "repository": "https://github.com/iamssen/eslint-plugin-solid",
  "license": "MIT",
  "author": "Seoyoen Lee <ssen1980@naver.com>",
  "contributors": [
    "Josh Wilson <joshwilsonvu@gmail.com>"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./configs/recommended": {
      "types": "./dist/configs/recommended.d.ts",
      "default": "./dist/configs/recommended.js"
    },
    "./configs/typescript": {
      "types": "./dist/configs/typescript.d.ts",
      "default": "./dist/configs/typescript.js"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "rimraf dist && rollup -c",
    "format": "prettier --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,mts,cts}\"",
    "lint": "eslint .",
    "test": "vitest --run",
    "test:all": "PARSER=all vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^7.13.1 || ^8.0.0",
    "estraverse": "^5.3.0",
    "is-html": "^2.0.0",
    "kebab-case": "^1.0.2",
    "known-css-properties": "^0.30.0",
    "style-to-object": "^1.0.6"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@microsoft/api-extractor": "^7.47.6",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/babel__core": "^7.20.5",
    "@types/eslint": "^9.6.1",
    "@types/eslint__js": "^8.42.3",
    "@types/eslint-v8": "npm:@types/eslint@^8",
    "@types/eslint-v9": "npm:@types/eslint@^9",
    "@types/estraverse": "^5.1.7",
    "@types/is-html": "^2.0.2",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-plugin": "^7.3.3",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-unicorn": "^68.0.0",
    "eslint-v8": "npm:eslint@^8",
    "eslint-v9": "npm:eslint@^9",
    "prettier": "^3.8.4",
    "@prettier/sync": "^0.6.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "tsx": "^4.17.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^1.5.2"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0 || ^10.0.0",
    "typescript": ">=4.8.4"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}
