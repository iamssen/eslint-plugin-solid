{
  "name": "@iamssen/eslint-plugin-solid",
  "version": "0.14.5",
  "description": "Solid-specific linting rules for ESLint.",
  "type": "module",
  "keywords": [
    "eslint",
    "eslintplugin",
    "solid",
    "solidjs",
    "reactivity"
  ],
  "repository": "https://github.com/solidjs-community/eslint-plugin-solid",
  "license": "MIT",
  "author": "Josh Wilson <joshwilsonvu@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./configs/recommended": {
      "types": "./dist/configs/recommended.d.ts",
      "default": "./dist/configs/recommended.js"
    },
    "./configs/typescript": {
      "types": "./dist/configs/typescript.d.ts",
      "default": "./dist/configs/typescript.js"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest --run",
    "test:all": "PARSER=all vitest --run",
    "test:babel": "PARSER=babel vitest --run",
    "test:ts": "PARSER=ts vitest --run",
    "test:watch": "vitest",
    "docs": "PARSER=none tsx scripts/docs.ts"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^7.13.1 || ^8.0.0",
    "estraverse": "^5.3.0",
    "is-html": "^2.0.0",
    "kebab-case": "^1.0.2",
    "known-css-properties": "^0.30.0",
    "style-to-object": "^1.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/eslint-parser": "^7.24.7",
    "@microsoft/api-extractor": "^7.47.6",
    "@tsconfig/node20": "^20.1.9",
    "@types/babel__core": "~7.20.5",
    "@types/eslint": "^8.56.10",
    "@types/eslint__js": "^8.42.3",
    "@types/eslint-v8": "npm:@types/eslint@8",
    "@types/estraverse": "^5.1.7",
    "@types/is-html": "^2.0.2",
    "@types/markdown-magic": "~1.0.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.5.0",
    "eslint-v8": "npm:eslint@8",
    "markdown-magic": "^3.3.0",
    "prettier": "^2.8.8",
    "tsup": "^8.2.4",
    "tsx": "^4.17.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^1.5.2"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0",
    "typescript": ">=4.8.4"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}
